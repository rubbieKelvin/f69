# Copy to `backend/.env` for local runs (`dotenvy` loads it). Do not commit `.env`.

# --- Postgres (matches docker-compose defaults) ---
# POSTGRES_USER=f69
# POSTGRES_PASSWORD=f69dev

# --- Auth service: env prefix AUTH_ (nested keys use AUTH__SECTION__KEY) ---
AUTH_HOST=0.0.0.0
AUTH_PORT=3000
AUTH_DATABASE_URL=postgres://f69:f69dev@localhost:5432/auth
# Prefer file path for the RSA private key PEM (generate with `openssl genrsa -out deploy/dev-jwt.pem 2048`)
AUTH_JWT_PRIVATE_KEY_PATH=deploy/dev-jwt.pem
# AUTH_JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
AUTH_JWT_ISSUER=f69-auth
AUTH_JWT_AUDIENCE=f69-api
AUTH_JWT_ACCESS_TTL_SECS=3600
AUTH_ENVIRONMENT=development
AUTH_RUN_MIGRATIONS_ON_STARTUP=true
# AUTH_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com

# --- Flag service: env prefix FLAG_ ---
FLAG_HOST=0.0.0.0
FLAG_PORT=3001
FLAG_DATABASE_URL=postgres://f69:f69dev@localhost:5432/flags
FLAG_AUTH_BASE_URL=http://localhost:3000
FLAG_JWT_ISSUER=f69-auth
FLAG_JWT_AUDIENCE=f69-api
FLAG_ENVIRONMENT=development
FLAG_RUN_MIGRATIONS_ON_STARTUP=true
# FLAG_CORS_ALLOWED_ORIGINS=http://localhost:5173

RUST_LOG=info,tower_http=info
